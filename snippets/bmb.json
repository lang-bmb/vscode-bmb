{
  "Function": {
    "prefix": "fn",
    "body": [
      "fn ${1:name}(${2:params}) -> ${3:ReturnType} = ${4:body};"
    ],
    "description": "Define a function"
  },
  "Function with Contract": {
    "prefix": "fnc",
    "body": [
      "fn ${1:name}(${2:params}) -> ${3:ReturnType}",
      "  pre ${4:condition}",
      "  post ${5:ret_condition}",
      "= ${6:body};"
    ],
    "description": "Define a function with pre/post contracts"
  },
  "Function with Block": {
    "prefix": "fnb",
    "body": [
      "fn ${1:name}(${2:params}) -> ${3:ReturnType} = {",
      "    ${4:body}",
      "};"
    ],
    "description": "Define a function with block body"
  },
  "Precondition": {
    "prefix": "pre",
    "body": [
      "pre ${1:condition}"
    ],
    "description": "Add a precondition"
  },
  "Postcondition": {
    "prefix": "post",
    "body": [
      "post ${1:condition}"
    ],
    "description": "Add a postcondition"
  },
  "Postcondition with ret": {
    "prefix": "postr",
    "body": [
      "post ret ${1:>= 0}"
    ],
    "description": "Add a postcondition using ret"
  },
  "Let Binding": {
    "prefix": "let",
    "body": [
      "let ${1:name} = ${2:value};"
    ],
    "description": "Create a let binding"
  },
  "Let with Type": {
    "prefix": "lett",
    "body": [
      "let ${1:name}: ${2:Type} = ${3:value};"
    ],
    "description": "Create a typed let binding"
  },
  "If-Then-Else": {
    "prefix": "if",
    "body": [
      "if ${1:condition} then ${2:true_branch} else ${3:false_branch}"
    ],
    "description": "If-then-else expression"
  },
  "If-Then-Else (multiline)": {
    "prefix": "ifm",
    "body": [
      "if ${1:condition}",
      "  then ${2:true_branch}",
      "  else ${3:false_branch}"
    ],
    "description": "Multi-line if-then-else expression"
  },
  "Struct": {
    "prefix": "struct",
    "body": [
      "struct ${1:Name} {",
      "    ${2:field}: ${3:Type},",
      "}"
    ],
    "description": "Define a struct"
  },
  "Enum": {
    "prefix": "enum",
    "body": [
      "enum ${1:Name} {",
      "    ${2:Variant1},",
      "    ${3:Variant2},",
      "}"
    ],
    "description": "Define an enum"
  },
  "Type Alias": {
    "prefix": "type",
    "body": [
      "type ${1:Name} = ${2:Type};"
    ],
    "description": "Create a type alias"
  },
  "Refinement Type": {
    "prefix": "typer",
    "body": [
      "type ${1:Name} = ${2:BaseType} where ${3:self != 0};"
    ],
    "description": "Create a refinement type with constraint"
  },
  "For-All Quantifier": {
    "prefix": "forall",
    "body": [
      "forall(${1:i} in ${2:0}..${3:len}): ${4:condition}"
    ],
    "description": "Universal quantifier"
  },
  "Exists Quantifier": {
    "prefix": "exists",
    "body": [
      "exists(${1:i} in ${2:0}..${3:len}): ${4:condition}"
    ],
    "description": "Existential quantifier"
  },
  "Match Expression": {
    "prefix": "match",
    "body": [
      "match ${1:expr} {",
      "    ${2:Pattern1} => ${3:value1},",
      "    ${4:Pattern2} => ${5:value2},",
      "}"
    ],
    "description": "Pattern matching expression"
  },
  "Trust Attribute": {
    "prefix": "@trust",
    "body": [
      "@trust",
      "fn ${1:name}(${2:params}) -> ${3:ReturnType}",
      "  pre ${4:condition}",
      "= ${5:body};"
    ],
    "description": "Define a trusted function (skip verification)"
  },
  "Check Attribute": {
    "prefix": "@check",
    "body": [
      "@check",
      "fn ${1:name}(${2:params}) -> ${3:ReturnType}",
      "  post ${4:condition}",
      "= ${5:body};"
    ],
    "description": "Define a function with runtime check fallback"
  },
  "Test Function": {
    "prefix": "@test",
    "body": [
      "@test",
      "fn test_${1:name}() -> bool = {",
      "    ${2:// Test implementation}",
      "    true",
      "};"
    ],
    "description": "Define a test function"
  },
  "Benchmark Function": {
    "prefix": "@bench",
    "body": [
      "@bench",
      "fn bench_${1:name}(n: i64) -> i64 = {",
      "    ${2:// Benchmark implementation}",
      "    0",
      "};"
    ],
    "description": "Define a benchmark function"
  },
  "Invariant": {
    "prefix": "invariant",
    "body": [
      "invariant ${1:condition}"
    ],
    "description": "Loop invariant"
  },
  "Decreases": {
    "prefix": "decreases",
    "body": [
      "decreases ${1:expression}"
    ],
    "description": "Termination measure"
  },
  "Old Value": {
    "prefix": "old",
    "body": [
      "old(${1:variable})"
    ],
    "description": "Reference to value at function entry"
  },
  "Low-Level Block": {
    "prefix": "low",
    "body": [
      "low {",
      "    ${1:// Low-level operations}",
      "}"
    ],
    "description": "Low-level block for SIMD/pointer operations"
  },
  "Tail-Recursive Pattern": {
    "prefix": "tailrec",
    "body": [
      "fn ${1:name}_iter(${2:n}: i64, ${3:acc}: ${4:i64}) -> ${4} =",
      "    if ${2} <= ${5:0} then ${3}",
      "    else ${1}_iter(${2} - 1, ${6:acc + n});",
      "",
      "fn ${1}(${2}: i64) -> ${4}",
      "  pre ${2} >= 0",
      "= ${1}_iter(${2}, ${7:0});"
    ],
    "description": "Tail-recursive accumulator pattern"
  },
  "Main Function": {
    "prefix": "main",
    "body": [
      "fn main() -> i64 = {",
      "    ${1:// Entry point}",
      "    0",
      "};"
    ],
    "description": "Program entry point"
  },
  "Use Statement": {
    "prefix": "use",
    "body": [
      "use ${1:module};"
    ],
    "description": "Import a module"
  },
  "Println": {
    "prefix": "println",
    "body": [
      "println(${1:value});"
    ],
    "description": "Print value to console"
  }
}
